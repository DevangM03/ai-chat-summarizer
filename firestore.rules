rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. USER PROFILE SECURITY BOUNDARY
    // Users can only read or write their own user profile document.
    // This prevents malicious actors from extracting user lists or manipulating user nicknames.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 2. REAL-TIME CHAT MESSAGE BOUNDARY
    // Allows authenticated users to participate in chat streaming loops.
    // Validates that inbound text content meets basic lengths to prevent database flooding.
    match /rooms/{roomId}/messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.data.text.size() > 0 
                    && request.resource.data.text.size() < 5000
                    && request.resource.data.uid == request.auth.uid;
      // Messages should be immutable in a clean audit trail chat log; explicitly disallow updates/deletes
      allow update, delete: if false;
    }
    
    // 3. AI PIPELINE & ANALYTICS DATA SINK PROTECTION
    // Protects the analytical data structures compiled by the Gemini pipeline.
    // Restricts malicious deletion of core business telemetry.
    match /rooms/{roomId}/analytics/{analysisId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}